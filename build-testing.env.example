# -----------------------------------------------------------------------------
# Optional settings for ./build-testing.sh — copy to build-testing.env and edit.
# File build-testing.env is gitignored and is not pushed to GitHub.
#
# Location: repository root, next to build-testing.sh.
#
# Precedence: variables you export in the shell before running ./build-testing.sh
# override values from build-testing.env (same pattern as marc0janssen/nzbgetvpn).
# -----------------------------------------------------------------------------

# Docker Hub repository (namespace/name, NO tag). Used for image tags and docker pushrm.
DOCKER_IMAGE_REPO=marc0janssen/restic-backup-helper

# Passed to: docker buildx build --platform ...
BUILD_PLATFORM=linux/amd64,linux/arm64

# Must match the Restic base image tag patched into Dockerfile (FROM restic/restic:...).
# VERSION_RESTIC=0.18.1
