# -----------------------------------------------------------------------------
# Template for ./build-testing-local.sh — copy to build-testing-local.env and edit.
# File build-testing-local.env is gitignored and is not pushed to GitHub.
#
# Location: repository root, next to build-testing-local.sh.
# -----------------------------------------------------------------------------

# Target repository on your private registry (host:port/image path, NO tag).
# Tags pushed: :develop and :<release> (e.g. 2.9.0-0.18.1-dev).
# Image has ENV RESTIC_BACKUP_HELPER_RELEASE from build-arg.
LOCAL_REPO=192.168.1.1:5000/restic-backup-helper

# Optional. Passed to: docker buildx build --platform ...
# Examples: linux/amd64 or linux/amd64,linux/arm64
# LOCAL_PLATFORM=linux/amd64,linux/arm64

# Optional. Same meaning as in build-testing.sh — must match the FROM line you want.
# CLI alternative: ./build-testing-local.sh --base 0.18.2
# Use 'newest' (alias 'latest') to auto-resolve via 'docker run --rm restic/restic:latest version'.
# Use 'prerelease' (aliases 'rc' / 'beta') to auto-resolve the newest Docker Hub rc/beta image tag.
# Any other non-version value is rejected before the build starts.
# The build verifies restic/restic:<tag> actually exists on Docker Hub and patches
# Dockerfile FROM so the pushed image always matches the version in the tag.
# VERSION_RESTIC=0.18.1
